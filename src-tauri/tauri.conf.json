{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meetings Assistant",
  "version": "0.1.0",
  "identifier": "com.meetingsassistant.recorder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Meetings Assistant",
        "width": 1120,
        "height": 720,
        "minWidth": 920,
        "minHeight": 620,
        "maxWidth": 1440,
        "maxHeight": 960,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      },
      {
        "label": "widget",
        "title": "Meetings Assistant Widget",
        "width": 430,
        "height": 56,
        "minWidth": 430,
        "minHeight": 56,
        "maxWidth": 430,
        "maxHeight": 56,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/**",
          "$LOCALDATA/MeetingsAssistant/**",
          "$HOME/Music/Meetings Assistant/**",
          "$AUDIO/Meetings Assistant/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"]
  },
  "plugins": {}
}
